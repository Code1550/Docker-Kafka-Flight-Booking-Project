# ──────────────────────────────────────────
# POSTGRESQL
# ──────────────────────────────────────────
POSTGRES_USER=flightuser
POSTGRES_PASSWORD=flightsecret
POSTGRES_DB=flightbooking
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ──────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────
REDIS_PASSWORD=redissecret
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
SEAT_LOCK_TTL_SECONDS=300

# ──────────────────────────────────────────
# KAFKA
# ──────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=false

# Consumer group IDs (one per service)
BOOKING_SERVICE_GROUP=booking-service-group
SEAT_SERVICE_GROUP=seat-service-group
PAYMENT_SERVICE_GROUP=payment-service-group
NOTIFICATION_SERVICE_GROUP=notification-service-group

# Topic names
TOPIC_BOOKING_REQUESTED=booking.requested
TOPIC_SEAT_RESERVED=seat.reserved
TOPIC_SEAT_UNAVAILABLE=seat.unavailable
TOPIC_PAYMENT_PROCESSED=payment.processed
TOPIC_PAYMENT_FAILED=payment.failed
TOPIC_BOOKING_CONFIRMED=booking.confirmed
TOPIC_BOOKING_FAILED_DLQ=booking.failed.dlq

# ──────────────────────────────────────────
# API GATEWAY
# ──────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=changeme-use-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=true

# ──────────────────────────────────────────
# PAYMENT SERVICE
# ──────────────────────────────────────────
STRIPE_MOCK_ENABLED=true
STRIPE_API_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme
PAYMENT_RETRY_ATTEMPTS=3
PAYMENT_RETRY_DELAY_SECONDS=2

# ──────────────────────────────────────────
# NOTIFICATION SERVICE
# ──────────────────────────────────────────
SENDGRID_MOCK_ENABLED=true
SENDGRID_API_KEY=SG.changeme
NOTIFICATION_FROM_EMAIL=noreply@flightbooking.com
NOTIFICATION_FROM_NAME=Flight Booking System

# ──────────────────────────────────────────
# MONITORING
# ──────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
PROMETHEUS_RETENTION_DAYS=7